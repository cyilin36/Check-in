KF_USERNAME=your_username
KF_PASSWORD=your_password
YNGAL_EMAIL=your_email@example.com
YNGAL_PASSWORD=your_password
TZ=Asia/Shanghai
KF_CHECKIN_TIME=08:00
YNGAL_CHECKIN_TIME=08:00
YNGAL_HUNT_ENABLED=true
REQUEST_TIMEOUT=20
LOG_LEVEL=INFO

# AstrBot Push Lite（URL、TOKEN、UMO 需同时取消注释并填写）
# PUSH_LITE_URL=http://astrbot:9966/send
# PUSH_LITE_TOKEN=your_api_token
# PUSH_LITE_UMO=your_session_umo
PUSH_LITE_NOTIFY_MODE=failure
PUSH_LITE_TIMEOUT=10
